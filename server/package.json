{
  "name": "@caldir/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" }
  },
  "bin": {
    "caldir-server": "./dist/main.js"
  },
  "dependencies": {
    "@caldir/shared": "0.1.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "20",
    "@types/ws": "^8.5.12",
    "tsx": "^4.23.0",
    "typescript": "5.5"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  }
}
